generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  image     String?
  createdAt DateTime @default(now())

  favorites Favorite[]
}

model Drama {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  description   String
  coverImage    String
  bannerImage   String
  trailerUrl    String?
  country       String
  year          Int
  rating        Float
  status        String
  genres        String[]
  favorites Favorite[]

  scheduleDay   String?
  scheduleTime  String?

  createdAt     DateTime @default(now())

  episodes      Episode[]
}

model Episode {
  id           String   @id @default(cuid())
  number       Int
  title        String
  description  String?
  thumbnail    String
  videoUrl     String
  duration     Int
  releaseDate  DateTime
  createdAt    DateTime @default(now())

  dramaId String
  drama   Drama @relation(fields: [dramaId], references: [id], onDelete: Cascade)
}

model Favorite {

  id        String   @id @default(cuid())

  userId    String
  dramaId   String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  drama     Drama    @relation(fields: [dramaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, dramaId])

}

enum Role {
  USER
  ADMIN
}